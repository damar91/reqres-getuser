    {
      "name": "https://reqres.in/api/users?page=2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "//API-001\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//API-002\r",
              "pm.test(\"Data is an array\", function () {\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "//API-003\r",
              "pm.test(\"Each user has required fields\", function () {\r",
              "    jsonData.data.forEach(user => {\r",
              "        pm.expect(user).to.have.property(\"id\");\r",
              "        pm.expect(user).to.have.property(\"email\");\r",
              "        pm.expect(user).to.have.property(\"first_name\");\r",
              "        pm.expect(user).to.have.property(\"last_name\");\r",
              "        pm.expect(user).to.have.property(\"avatar\");\r",
              "    });\r",
              "});\r",
              "\r",
              "//API-004\r",
              "pm.test(\"Email format validation\", function () {\r",
              "    jsonData.data.forEach(user => {\r",
              "        pm.expect(user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);\r",
              "    });\r",
              "});\r",
              "\r",
              "//API-009\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
